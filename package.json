{
  "name": "expert-brain",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "wrangler dev",
    "build:bundles": "tsx scripts/build-bundles.ts",
    "deploy": "npm run build:bundles && node scripts/deploy.mjs",
    "backfill-similar": "node scripts/backfill-similar.mjs",
    "test": "vitest run && vitest run --config vitest.auth.config.ts",
    "test:client": "vitest run --config vitest.client.config.ts",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "dev:full": "wrangler dev -c wrangler.toml -c ../expert-contacts/wrangler.toml",
    "seed:dev": "node scripts/seed-dev.mjs --local --force",
    "verify:wave": "node scripts/verify-wave.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/web/client/tsconfig.json && tsc --noEmit -p test/client/tsconfig.json && tsc --noEmit -p e2e/tsconfig.json",
    "install-hooks": "node scripts/install-hooks.mjs",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.0.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/d3-force": "^3.0.10",
    "3d-force-graph": "^1.80.0",
    "agents": "^0.17.3",
    "d3-force": "^3.0.0",
    "fuse.js": "^7.3.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "marked": "^18.0.0",
    "nanoid": "^5.0.0",
    "sigma": "^3.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@playwright/test": "^1.61.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "adm-zip": "^0.5.16",
    "esbuild": "^0.28.0",
    "graphology-types": "^0.24.8",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.81.1"
  }
}
