#!/bin/sh
# Bloqueia commit acidental do wrangler.toml — ele contém IDs reais de
# infra Cloudflare (account_id, D1, KV) e mora no .gitignore.
# Instala via `npm run install-hooks`.

if git diff --cached --name-only | grep -qE '^wrangler\.toml$'; then
  echo ""
  echo "ERRO: wrangler.toml staged."
  echo ""
  echo "Esse arquivo contém account_id e IDs de D1/KV reais — não deve ser commitado."
  echo "Edite wrangler.example.toml em vez disso (template com placeholders REPLACE_ME_*)."
  echo ""
  echo "Pra desfazer o stage: git restore --staged wrangler.toml"
  echo ""
  exit 1
fi
